<Window
    x:Class="PrisPilot.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrisPilot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:PrisPilot.ViewModels"
    xmlns:views="clr-namespace:PrisPilot.Views"
    Title="MainWindow"
    Width="800"
    Height="450"
    Background="White"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="75" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button
                Width="auto"
                Margin="10"
                Command="{Binding NavigateToFirstViewCommand}"
                Content="Opret kunde" />
            <Button
                Width="auto"
                Margin="10"
                Content="Opret tilbud" />
        </StackPanel>

        <ContentControl
            x:Name="Main"
            Grid.Row="1"
            Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
