<Window
    x:Class="PrisPilot.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrisPilot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:PrisPilot.ViewModels"
    xmlns:views="clr-namespace:PrisPilot.Views"
    Title="MainWindow"
    Width="1080"
    Height="1920"
    Background="#FBF8F4"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <!--#region Header-->
        <Image
            Grid.Row="0"
            Width="auto"
            Height="auto"
            Margin="0,0,30,0"
            HorizontalAlignment="Right"
            Source="pack://application:,,,/Assets/Logo/Drossel_Logo.png" />
        <StackPanel
            Grid.Row="0"
            Margin="40,0,0,0"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Button
                x:Name="Add_Customer_Button"
                Grid.Row="0"
                Grid.Column="1"
                Height="148"
                MaxHeight="30"
                Margin="0,0,30,0"
                Padding="20,2"
                Background="{StaticResource WarmBackgroundBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1.5"
                Content="Opret Kunde"
                Foreground="Black" />
            <Button
                x:Name="New_Quote_Button"
                Grid.Row="0"
                Grid.Column="1"
                MaxHeight="30"
                Margin="0,0,30,0"
                Padding="20,2"
                Background="{StaticResource WarmBackgroundBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1.5"
                Command="{Binding NavigateToFirstViewCommand}"
                Content="Nyt tilbud" />
            <Button
                x:Name="Preview_Button"
                Grid.Row="0"
                Grid.Column="1"
                MaxHeight="30"
                Margin="0,0,30,0"
                Padding="20,2"
                Background="{StaticResource WarmBackgroundBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1.5"
                Command="{Binding NavigateToSecondViewCommand}"
                Content="Forhåndsvisning" />
            <Button
                x:Name="Customer_Overview_Button"
                Grid.Row="0"
                Grid.Column="1"
                MaxHeight="30"
                Margin="0,0,30,0"
                Padding="20,2"
                Background="{StaticResource WarmBackgroundBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1.5"
                Content="Kundeoversigt" />


        </StackPanel>
        <!--#endregion-->



        <ContentControl
            x:Name="Main"
            Grid.Row="1"
            Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
