<UserControl
    x:Class="PrisPilot.Views.AddCustomerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrisPilot.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">
    <!--#region Resources and style-->
    <UserControl.Resources>
        <Style TargetType="Button">
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5" />
                </Style>
            </Style.Resources>
        </Style>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#172E79" />
        <SolidColorBrush x:Key="AccentBrush" Color="#EF8802" />
        <SolidColorBrush x:Key="WarmBackgroundBrush" Color="#FBF8F4" />
        <SolidColorBrush x:Key="SoftBorderBrush" Color="#D1D5DB" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="CardGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="White" />
        </Style>
    </UserControl.Resources>
    <!--#endregion-->

    <!--#region Grid-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="4*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition />
            <ColumnDefinition Width="100" />
        </Grid.ColumnDefinitions>


        <!--#region Content box-->

        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />

            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="Firmanavn:" />
            <TextBox
                Grid.Row="0"
                Grid.Column="1"
                Height="30"
                Margin="0,0,150,16" />
            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="Kontaktperson: " />
            <TextBox
                Grid.Row="1"
                Grid.Column="1"
                Height="30"
                Margin="0,0,150,16" />

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="CVR:" />
            <TextBox
                Grid.Row="2"
                Grid.Column="1"
                Height="30"
                Margin="0,0,150,16" />
            <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="Email:" />
            <TextBox
                Grid.Row="3"
                Grid.Column="1"
                Height="30"
                Margin="0,0,150,16" />
            <TextBlock
                Grid.Row="4"
                Grid.Column="0"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="Telefonnummer:" />
            <TextBox
                Grid.Row="4"
                Grid.Column="1"
                Height="30"
                Margin="0,0,150,16" />

            <TextBlock
                Grid.Row="5"
                Grid.Column="0"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="Adresse:" />
            <TextBox
                Grid.Row="5"
                Grid.Column="1"
                Height="30"
                Margin="0,0,150,16" />
            <TextBlock
                Grid.Row="6"
                Grid.Column="0"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="Timeløn:" />
            <TextBox
                Grid.Row="6"
                Grid.Column="1"
                Height="30"
                Margin="0,0,150,16" />
            <Button
                Grid.Row="7"
                Height="25"
                Command="{Binding OpenFileForAddCustomerCommand}"
                CommandParameter="{Binding}"
                Content="Hent logo" />
            <TextBlock
                Grid.Row="7"
                Grid.Column="2"
                Margin="30,0,12,16"
                VerticalAlignment="Center"
                FontSize="25"
                Foreground="{StaticResource PrimaryBrush}"
                Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Height="2"
            Margin="0,0,0,10"
            Background="{StaticResource AccentBrush}" />


        <Border
            Grid.Row="2"
            Grid.Column="1"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2" />
        <!--#endregion-->


    </Grid>
    <!--#endregion Grid-->
</UserControl>